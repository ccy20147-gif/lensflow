    "axios": "^1.7.0",
    "lucide-vue-next": "^0.460.0",
    "pinia": "^2.2.0",
    "reka-ui": "^2.0.0",
    "vue": "^3.5.0",
    "vue-json-pretty": "^2.4.0",
    "vue-router": "^4.4.0",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
