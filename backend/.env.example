# ToonFlow Backend — Demo Environment
# Copy to backend/.env and adjust as needed for local development.

# App
APP_NAME=ToonFlow API
APP_VERSION=0.1.0
DEBUG=true

# Database (PostgreSQL via docker-compose)
DATABASE_URL=postgresql+asyncpg://toonflow:toonflow@localhost:5432/toonflow
DATABASE_URL_SYNC=postgresql+psycopg2://toonflow:toonflow@localhost:5432/toonflow

# Redis (queue / outbox dispatcher; optional in Demo phase)
REDIS_URL=redis://localhost:6379/0

# JWT — empty in Demo phase; will use the SqlSessionStore for tokens.
JWT_PUBLIC_KEY=
JWT_PRIVATE_KEY=
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS — allow Vite dev server.
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Blob storage (local FS for Demo; S3-compatible in production)
BLOB_STORAGE_PATH=/tmp/toonflow-blobs

# ---------------------------------------------------------------------------
# Local development setup with Docker:
#
#   docker run -d --name toonflow-pg \
#     -e POSTGRES_USER=toonflow \
#     -e POSTGRES_PASSWORD=toonflow \
#     -e POSTGRES_DB=toonflow \
#     -p 5432:5432 \
#     postgres:16-alpine
#
# Then run:
#   cd backend
#   uv sync --all-extras
#   uv run alembic upgrade head
#   uv run uvicorn src.app:app --host 0.0.0.0 --port 8000 --reload
# ---------------------------------------------------------------------------